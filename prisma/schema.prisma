// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ======================Enums =========================

enum UserRole {
  ADMIN
  VENDOR
  CUSTOMER
}

enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
}

enum CertificationStatus {
  APPROVED
  PENDING
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}


// ======================User Model =========================

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  role           UserRole        @default(CUSTOMER)
  status         UserStatus      @default(ACTIVE)
  isDeleted      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  vendorProfile  VendorProfile?
  communityPosts CommunityPost[]
  orders         Order[]
  plants         Plant[]

  @@index([role])
  @@index([status])
  @@index([isDeleted])
  @@map("users")
}

// ======================Vendor Profile Model =========================

model VendorProfile {
  id                  String               @id @default(uuid())
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id])
  farmName            String
  farmLocation        String
  certificationStatus String
  isDeleted           Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  produce             Produce?
  rentalSpaces        RentalSpace[]
  sustainabilityCerts SustainabilityCert[]

  @@index([userId])
  @@index([farmName])
  @@index([farmLocation])
  @@index([certificationStatus])
  @@index([isDeleted])
  @@map("vendor_profiles")
}

// ======================Produce Model =========================

model Produce {
  id                  String              @id @default(uuid())
  name                String
  description         String
  price               Decimal             @db.Decimal(10, 2)
  category            String
  availableQuantity   Int
  vendorId            String              @unique
  vendor              VendorProfile       @relation(fields: [vendorId], references: [id])
  certificationStatus CertificationStatus
  isDeleted           Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  orders              Order[]

  @@index([vendorId])
  @@index([isDeleted])
  @@map("produces")
}

// ======================Rental Space Model =========================

model RentalSpace {
  id           String        @id @default(uuid())
  vendorId     String
  vendor       VendorProfile @relation(fields: [vendorId], references: [id])
  location     String
  size         String
  price        Float
  availability Boolean       @default(true)
  isDeleted    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([vendorId])
  @@index([isDeleted])
  @@map("rental_spaces")
}

// ====================== Community Post Model =========================

model CommunityPost {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  postContent String
  postDate    DateTime @default(now())
  isDeleted   Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([isDeleted])
  @@map("community_posts")
}

// ====================== Sustainability Cert Model =========================

model SustainabilityCert {
  id                String              @id @default(uuid())
  vendorId          String
  vendor            VendorProfile       @relation(fields: [vendorId], references: [id])
  certifyingAgency  String
  certificationDate DateTime
  fileUrl           String
  status            CertificationStatus @default(PENDING)
  isDeleted         Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([vendorId])
  @@index([isDeleted])
  @@map("sustainability_certs")
}

//  ========================= Order Model =========================

model Order {
  id         String      @id @default(uuid())
  produceId  String
  produce    Produce     @relation(fields: [produceId], references: [id])
  customerId String
  customer   User        @relation(fields: [customerId], references: [id])
  quantity   Int
  totalPrice Decimal     @db.Decimal(10, 2)
  status     OrderStatus @default(PENDING)
  isDeleted  Boolean     @default(false)
  orderDate  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([produceId])
  @@index([customerId])
  @@index([isDeleted])
  @@map("orders")
}

// ====================== Plant Model =========================

model Plant {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  name            String
  species         String?
  plantingDate    DateTime  @default(now())
  expectedHarvest DateTime?
  status          String    @default("GROWING")
  healthStatus    String    @default("HEALTHY")
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([isDeleted])
  @@map("plants")
}

